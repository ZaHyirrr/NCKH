# Render Web Service: nckh-backend-spring
# Copy these keys into Render dashboard (Environment tab).

JAVA_VERSION=17
PORT=10000

# Aiven MySQL (JDBC URL, not mysql:// URI)
# Format:
# jdbc:mysql://<host>:<port>/<db>?sslMode=REQUIRED&serverTimezone=UTC
DATABASE_URL=jdbc:mysql://nckh-mysql-1-leminhquan2878-a096.d.aivencloud.com:21026/defaultdb?sslMode=REQUIRED&serverTimezone=UTC
DB_USERNAME=avnadmin
DB_PASSWORD=REPLACE_ME

JPA_DDL_AUTO=update

# Must be at least 32 chars
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Add frontend domain after frontend is created on Render
# Example: https://nckh-frontend.onrender.com
CORS_ALLOWED_ORIGINS=REPLACE_WITH_FRONTEND_URL
